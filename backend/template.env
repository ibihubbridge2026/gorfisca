# GORFISCA - Template Configuration Environment Variables
# Copiez ce fichier vers .env et remplissez les valeurs réelles

# ==========================================
# DJANGO SETTINGS
# ==========================================
DEBUG=False
SECRET_KEY=your-super-secret-key-change-this-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# ==========================================
# DATABASE CONFIGURATION
# ==========================================
# PostgreSQL (Production)
DATABASE_URL=postgresql://username:password@localhost:5432/gorfisca_prod
DB_NAME=gorfisca_prod
DB_USER=gorfisca_user
DB_PASSWORD=secure_password_change_me
DB_HOST=localhost
DB_PORT=5432

# SQLite (Development - par défaut)
# DATABASE_URL=sqlite:///db.sqlite3

# ==========================================
# CACHE CONFIGURATION
# ==========================================
# Redis (Production)
REDIS_URL=redis://localhost:6379/1
CACHE_URL=redis://localhost:6379/1

# Local Memory (Development)
# CACHE_URL=locmemcache://

# ==========================================
# AI SERVICES
# ==========================================
# Mistral AI
MISTRAL_API_KEY=your-mistral-api-key-here
MISTRAL_MODEL_SMALL=mistral-small-latest
MISTRAL_MODEL_LARGE=mistral-large-latest

# ==========================================
# EMAIL CONFIGURATION
# ==========================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@gorfisca.com

# ==========================================
# SECURITY SETTINGS
# ==========================================
# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-domain.com
CORS_ALLOW_CREDENTIALS=True

# Session Security
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax
CSRF_COOKIE_SECURE=True
CSRF_COOKIE_HTTPONLY=True

# ==========================================
# MEDIA & STATIC FILES
# ==========================================
# S3/MinIO (Production)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_STORAGE_BUCKET_NAME=gorfisca-media
AWS_S3_REGION_NAME=us-east-1

# Local Storage (Development)
# MEDIA_ROOT=media/
# STATIC_ROOT=staticfiles/

# ==========================================
# LOGGING CONFIGURATION
# ==========================================
LOG_LEVEL=INFO
LOG_FILE_PATH=/var/log/gorfisca/app.log
SENTRY_DSN=your-sentry-dsn-for-error-tracking

# ==========================================
# MONITORING & HEALTH CHECKS
# ==========================================
HEALTH_CHECK_ENABLED=True
METRICS_ENABLED=True
PROMETHEUS_PORT=9090

# ==========================================
# BACKUP CONFIGURATION
# ==========================================
BACKUP_ENABLED=True
BACKUP_SCHEDULE=0 2 * * *  # Tous les jours à 2h du matin
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=gorfisca-backups

# ==========================================
# MULTI-TENANT SETTINGS
# ==========================================
DEFAULT_ORGANIZATION_NAME=Default Organization
MAX_USERS_PER_ORGANIZATION=50
MAX_ORGANIZATIONS=1000

# ==========================================
# PERFORMANCE SETTINGS
# ==========================================
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=30
REDIS_CONNECTION_POOL_SIZE=50

# ==========================================
# DEVELOPMENT ONLY
# ==========================================
# Ne pas utiliser en production!
# DEBUG=True
# ALLOWED_HOSTS=localhost,127.0.0.1
